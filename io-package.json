    "news": {
      "0.1.21": {
        "en": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "de": "Erste öffentliche Testversion mit serieller Kommunikation, Geräteanlage und DuoFern-Statusverarbeitung.",
        "ru": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "pt": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "nl": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "fr": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "it": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "es": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "pl": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "uk": "Initial public test version with serial communication, device creation and DuoFern state handling.",
        "zh-cn": "Initial public test version with serial communication, device creation and DuoFern state handling."
      },
      "0.1.22": {
        "en": "Handle missing serial port without uncaught exception.",
        "de": "Fehlenden seriellen Port ohne unbehandelte Exception behandeln."
      },
      "0.1.23": {
        "en": "Fixed send queue delay helper and normalized serial port path handling.",
        "de": "Sendequeue-delay-Hilfsfunktion korrigiert und Behandlung des seriellen Pfads normalisiert."
      },
      "0.1.24": {
        "en": "Added DuoFern stick initialization sequence, ACK handling and raw receive diagnostics.",
        "de": "DuoFern-Stick-Initialisierung, ACK-Verarbeitung und Rohdaten-Empfangsdiagnose ergänzt."
      },
      "0.1.25": {
        "en": "Fix initialization race by registering the response waiter before sending stick commands.",
        "de": "Initialisierungs-Race behoben: Antwort-Waiter wird vor dem Senden der Stick-Befehle registriert."
      },
      "0.1.26": {
        "en": "Restore the proven DuoFern runtime and keep compatibility with the current GitHub adapter structure.",
        "de": "Bewährte DuoFern-Laufzeitlogik wiederhergestellt und mit der aktuellen GitHub-Adapterstruktur kompatibel gemacht."
      }
    }
  },
  "native": {
    "port": "",
    "baudRate": 115200,
    "dongleSerial": "",
    "deviceCodes": "",
    "autoCreate": true,
    "ackIncoming": true,
    "initOnStart": true,
    "statusOnStart": true,
    "debugRaw": false,
    "flushPartialMs": 500,
    "commandTimeoutMs": 5000,
    "reconnectIntervalMs": 10000,
    "readAnswerTimeoutMs": 1000,
    "statusAfterCommand": true,
    "periodicStatusPoll": true,
    "periodicStatusPollMs": 60000,
    "externalActivityPollAll": true,
    "serialPort": "/dev/serial/by-id/usb-Rademacher_DuoFern_USB-Stick-if00-port0",
    "autoCreateDevices": true,
    "preserveUnknownValues": true,
    "createOnlySupportedStates": true
  },
