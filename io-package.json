      "ru": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "pt": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "nl": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "fr": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "it": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "es": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "pl": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
      "uk": "Adapter for Rademacher DuoFern USB stick with persistent state handling.",
